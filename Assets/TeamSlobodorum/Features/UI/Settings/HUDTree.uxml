            <ui:Label text="Press tab to open spell menu" name="AnnoucementDescription" style="margin-left: 7%; color: rgb(46, 46, 46); font-size: 14%; -unity-text-auto-size: best-fit 2px 30px; -unity-text-generator: advanced; margin-right: 7%; margin-bottom: 3%; margin-top: 1%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/cinzel/Cinzel-Regular.otf?fileID=12800000&amp;guid=1e1d71a23cc2d5c4d8271ad0868f745b&amp;type=3#Cinzel-Regular&quot;);"/>
