<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/TeamSlobodorum/Features/UI/Styles/hud.uss?fileID=7433441132597879392&amp;guid=2b87f580097f8d5498323833970fd3b4&amp;type=3#hud"/>
    <ui:VisualElement name="VisualElement" style="flex-grow: 1; align-items: stretch; justify-content: center; height: 20%;">
        <ui:Image source="" scale-mode="ScaleToFit" name="Crosshair" style="position: absolute; width: auto; height: 8%; align-self: center;"/>
        <ui:VisualElement name="Debuginfo" style="flex-grow: 1;">
            <ui:ProgressBar value="0.5" title="20/100" name="HealthBar" high-value="1" class="health_bar" style="margin-top: 3%; margin-right: 5%; margin-bottom: 1%; margin-left: 5%; width: 30%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/cinzel/Cinzel-Bold.otf?fileID=12800000&amp;guid=2ea35af805adeb141a2d173daf6b5813&amp;type=3#Cinzel-Bold&quot;);"/>
            <ui:ProgressBar value="0.5" title="100/100" name="ManaBar" high-value="1" class="mana_bar" style="margin-top: 1%; margin-right: 5%; margin-bottom: 2%; margin-left: 5%; width: 20%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/cinzel/Cinzel-Bold.otf?fileID=12800000&amp;guid=2ea35af805adeb141a2d173daf6b5813&amp;type=3#Cinzel-Bold&quot;);"/>
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:VisualElement style="flex-grow: 1; height: 60%;">
        <ui:VisualElement name="Annoucement" style="flex-grow: 0; width: 20%; height: 25%; flex-shrink: 0; margin-right: 0%; margin-left: 5%; margin-top: 0%; margin-bottom: 0%; background-color: rgb(215, 209, 185); transform-origin: center; translate: -125% 0; font-size: 100%; white-space: pre-wrap; text-overflow: clip;">
