                        <ui:VisualElement name="DetailsPanel" style="flex-grow: 1; width: 35%; margin-top: 2%; margin-right: 2%; margin-bottom: 2%; margin-left: 2%; background-color: rgb(43, 43, 43); padding-top: 2%; padding-right: 2%; padding-bottom: 2%; padding-left: 2%;">
                            <ui:Label text="Label" name="DetailName" style="height: 10%; color: rgb(244, 237, 209); font-size: 45%; -unity-text-align: middle-left; -unity-font-definition: url(&quot;project://database/Assets/Fonts/cinzel/Cinzel-Regular.otf?fileID=12800000&amp;guid=1e1d71a23cc2d5c4d8271ad0868f745b&amp;type=3#Cinzel-Regular&quot;);"/>
                            <ui:VisualElement name="DetailIcon" style="flex-grow: 1; color: rgb(0, 0, 0); background-color: rgb(180, 175, 154); height: 100px; width: 100px; min-width: 50px; min-height: 50px; aspect-ratio: 1; background-image: url(&quot;project://database/Assets/TeamSlobodorum/Features/Spells/SpellAssets/grab.png?fileID=2800000&amp;guid=93f6f67fc0e4ec24bb0d6877d1d4d10d&amp;type=3#grab&quot;); -unity-background-image-tint-color: rgb(255, 255, 255);"/>
                            <ui:Label text="" name="DetailDescription" style="height: 60%; color: rgb(244, 237, 209); font-size: 30%; width: 100%; text-overflow: clip; white-space: pre-wrap; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Cormorant_Garamond/static/CormorantGaramond-Medium.ttf?fileID=12800000&amp;guid=b38e250e5f3c05c4f9e89ff33502cd7b&amp;type=3#CormorantGaramond-Medium&quot;); -unity-text-align: upper-left;"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="SystemPage" style="flex-grow: 1; flex-direction: row; margin-top: 0; margin-right: 50px; margin-bottom: 0; margin-left: 50px; display: flex; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;">
                    <ui:VisualElement name="SystemOption" style="flex-grow: 0; width: 330px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; flex-shrink: 0;">
                        <ui:Label text="Save" name="Save" class="system-tab active"/>
                        <ui:Label text="Load" name="Load" class="system-tab"/>
                        <ui:Label text="Title Screen" name="Quit" class="system-tab"/>
                    </ui:VisualElement>
                    <ui:ScrollView name="SlotComponent" style="width: 70%; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 50px;">
